# Common registry prefix
DOCKER_REGISTRY=

ASPNETCORE_ENVIRONMENT=Production
DOTNET_ENVIRONMENT=Production

# Ports
WEB_HTTP_PORT=3000
APISERVICE_HTTP_PORT=8080
POSTGRES_PORT=9994
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
LOKI_PORT=3100
TEMPO_PORT=3200
OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318
OTEL_METRICS_PORT=8889

# API base URL consumed by the Web app
PUBLIC_API_BASE_URL=http://localhost:8080/api
PUBLIC_GOOGLE_CLIENT_ID=GOOGLE_OAUTH_CLIENT_ID.apps.googleusercontent.com

# Postgres
POSTGRES_USER=certval
POSTGRES_PASSWORD=certvalpw
# Database name
POSTGRES_DB=certval

# RabbitMQ
RABBITMQ_USER=certval
RABBITMQ_PASSWORD=certvalpw

# MinIO
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=miniopassword

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# CORS / API
Cors__AllowedOrigins__0=http://localhost:3000
Cors__AllowedOrigins__1=http://localhost:8080
CertificateStorage__BucketName=certificates
CertificateStorage__UseWorkspacePrefixes=true
CertificateStorage__DeleteOnCertificateRemoval=true
CertificateStorage__MaxFileSize=10485760

# App settings
JwtSettings__SecretKey=change-this-dE@fG-iJkMnPqR!tVwZz4t7w!z%C*F-JaNdRgUkXp2s5u8x/A?D(
JwtSettings__Issuer=CertVal
JwtSettings__Audience=CertVal-Users
JwtSettings__ExpiryHours=24

# Messaging defaults
Messaging__ExchangeName=certval-notifications
Messaging__EmailQueueName=email-notifications
Messaging__EmailRoutingKey=email
Messaging__DurableQueues=true
Messaging__PersistentMessages=true
Messaging__MaxRetryAttempts=3
Messaging__RetryDelay=00:05:00
Messaging__ConnectionTimeout=00:00:30
Messaging__MaxConnectionRetries=5

# Email service
EmailService__Smtp__Host=smtp.host
EmailService__Smtp__Port=587
EmailService__Smtp__UseSsl=true
EmailService__Smtp__SslMode=StartTls
EmailService__Smtp__Username=user
EmailService__Smtp__Password=password
EmailService__Smtp__FromEmail=noreply@certval.halerka.dev
EmailService__Smtp__FromName=CertVal
EmailService__SupportEmail=support@certval.halerka.dev
EmailService__CompanyName=CertVal
EmailService__BaseUrl=http://localhost:3000
EmailService__MaxRetryAttempts=3
EmailService__RetryDelay=00:05:00

# Notification settings
NotificationSettings__ProcessingInterval=00:15:00
NotificationSettings__MaxRetryAttempts=3
NotificationSettings__RetryDelay=00:05:00
