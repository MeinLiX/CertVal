# Common registry prefix
DOCKER_REGISTRY=

# Ports
WEB_HTTP_PORT=3000
POSTGRES_PORT=9994
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# API base URL consumed by the Web app
PUBLIC_API_BASE_URL=http://localhost:8080/api

# Postgres
POSTGRES_USER=certval
POSTGRES_PASSWORD=certvalpw
# Database name
POSTGRES_DB=certval

# RabbitMQ
RABBITMQ_USER=certval
RABBITMQ_PASSWORD=certvalpw

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# CORS / API
CORS_ALLOWED_ORIGINS__0=http://localhost:8080
CORS_ALLOWED_ORIGINS__1=http://localhost:3000
CERTIFICATE_BUCKET_NAME=certificates

# Messaging defaults
MESSAGING_EXCHANGE=certval-notifications
MESSAGING_EMAIL_QUEUE=email-notifications
MESSAGING_EMAIL_ROUTING_KEY=email
MESSAGING_DURABLE_QUEUES=true
MESSAGING_PERSISTENT_MESSAGES=true
MESSAGING_MAX_RETRY_ATTEMPTS=3
MESSAGING_RETRY_DELAY=00:05:00
MESSAGING_CONNECTION_TIMEOUT=00:00:30
MESSAGING_MAX_CONNECTION_RETRIES=5

# Email service
SMTP_HOST=
SMTP_PORT=587
SMTP_USE_SSL=true
SMTP_SSL_MODE=StartTls
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@certval.halerka.dev
SMTP_FROM_NAME=CertVal
EMAIL_BASE_URL=https://certval.halerka.dev
