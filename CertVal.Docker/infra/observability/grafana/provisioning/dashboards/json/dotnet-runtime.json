{
  "title": ".NET Runtime Metrics",
  "uid": "certval-dotnet-runtime",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "tags": [
    "dotnet",
    "runtime",
    "gc"
  ],
  "timezone": "browser",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "label": "Service",
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "query": "label_values(dotnet_process_memory_working_set_bytes, service_name)",
        "current": {
          "selected": false,
          "text": "All",
          "value": "$__all"
        },
        "includeAll": true,
        "multi": true,
        "refresh": 1
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Memory & GC Metrics",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Process Memory Working Set",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "expr": "dotnet_process_memory_working_set_bytes{service_name=~\"$service\"}",
          "legendFormat": "{{service_name}}"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true,
          "calcs": [
            "lastNotNull",
            "max",
            "mean"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2
          },
          "color": {
            "mode": "palette-classic"
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "GC Committed Memory",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "expr": "dotnet_gc_last_collection_memory_committed_size_bytes{service_name=~\"$service\"}",
          "legendFormat": "{{service_name}}"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true,
          "calcs": [
            "lastNotNull",
            "max"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2
          },
          "color": {
            "mode": "palette-classic"
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "GC Heap Size by Generation",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "expr": "dotnet_gc_last_collection_heap_size_bytes{service_name=~\"$service\"}",
          "legendFormat": "{{service_name}} Gen{{gc_heap_generation}}"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true,
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2
          },
          "color": {
            "mode": "palette-classic"
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "GC Heap Allocated Bytes",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 9
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "expr": "dotnet_gc_heap_allocated_bytes_total{service_name=~\"$service\"}",
          "legendFormat": "{{service_name}}"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true,
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2
          },
          "color": {
            "mode": "palette-classic"
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "GC Heap Fragmentation",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 9
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "expr": "dotnet_gc_last_collection_heap_fragmentation_size_bytes{service_name=~\"$service\"}",
          "legendFormat": "{{service_name}} Gen{{gc_heap_generation}}"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true,
          "calcs": [
            "lastNotNull",
            "max"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2
          },
          "color": {
            "mode": "palette-classic"
          }
        }
      }
    }
  ]
}