{
    "title": "Application Logs & Monitoring",
    "uid": "certval-app-logs-monitoring",
    "schemaVersion": 39,
    "version": 1,
    "editable": true,
    "tags": [
        "logs",
        "monitoring",
        "services"
    ],
    "timezone": "browser",
    "refresh": "10s",
    "time": {
        "from": "now-1h",
        "to": "now"
    },
    "templating": {
        "list": [
            {
                "name": "service",
                "type": "query",
                "label": "Service",
                "datasource": {
                    "type": "prometheus",
                    "uid": "Prometheus"
                },
                "query": "label_values(dotnet_process_memory_working_set_bytes, service_name)",
                "current": {
                    "selected": true,
                    "text": "CertVal.ApiService",
                    "value": "CertVal.ApiService"
                },
                "includeAll": false,
                "multi": false,
                "refresh": 2,
                "sort": 1
            }
        ]
    },
    "panels": [
        {
            "type": "row",
            "title": "Memory & GC Metrics",
            "gridPos": {
                "h": 1,
                "w": 24,
                "x": 0,
                "y": 0
            },
            "collapsed": false
        },
        {
            "type": "timeseries",
            "title": "Process Memory Working Set",
            "gridPos": {
                "h": 8,
                "w": 8,
                "x": 0,
                "y": 1
            },
            "datasource": {
                "type": "prometheus",
                "uid": "Prometheus"
            },
            "targets": [
                {
                    "refId": "A",
                    "datasource": {
                        "type": "prometheus",
                        "uid": "Prometheus"
                    },
                    "expr": "dotnet_process_memory_working_set_bytes{service_name=\"$service\"}",
                    "legendFormat": "{{service_name}}"
                }
            ],
            "options": {
                "legend": {
                    "displayMode": "table",
                    "placement": "bottom",
                    "showLegend": true,
                    "calcs": [
                        "lastNotNull",
                        "max",
                        "mean"
                    ]
                }
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "bytes",
                    "custom": {
                        "drawStyle": "line",
                        "fillOpacity": 10,
                        "lineWidth": 2
                    },
                    "color": {
                        "mode": "palette-classic"
                    }
                }
            }
        },
        {
            "type": "timeseries",
            "title": "GC Heap Allocated Bytes (Total)",
            "gridPos": {
                "h": 8,
                "w": 8,
                "x": 8,
                "y": 1
            },
            "datasource": {
                "type": "prometheus",
                "uid": "Prometheus"
            },
            "targets": [
                {
                    "refId": "A",
                    "datasource": {
                        "type": "prometheus",
                        "uid": "Prometheus"
                    },
                    "expr": "dotnet_gc_heap_allocated_bytes_total{service_name=\"$service\"}",
                    "legendFormat": "{{service_name}}"
                }
            ],
            "options": {
                "legend": {
                    "displayMode": "table",
                    "placement": "bottom",
                    "showLegend": true,
                    "calcs": [
                        "lastNotNull"
                    ]
                }
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "bytes",
                    "custom": {
                        "drawStyle": "line",
                        "fillOpacity": 10,
                        "lineWidth": 2
                    },
                    "color": {
                        "mode": "palette-classic"
                    }
                }
            }
        },
        {
            "type": "timeseries",
            "title": "GC Heap Size by Generation",
            "gridPos": {
                "h": 8,
                "w": 8,
                "x": 16,
                "y": 1
            },
            "datasource": {
                "type": "prometheus",
                "uid": "Prometheus"
            },
            "targets": [
                {
                    "refId": "A",
                    "datasource": {
                        "type": "prometheus",
                        "uid": "Prometheus"
                    },
                    "expr": "dotnet_gc_last_collection_heap_size_bytes{service_name=\"$service\"}",
                    "legendFormat": "Gen {{gc_heap_generation}}"
                }
            ],
            "options": {
                "legend": {
                    "displayMode": "table",
                    "placement": "bottom",
                    "showLegend": true,
                    "calcs": [
                        "lastNotNull"
                    ]
                }
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "bytes",
                    "custom": {
                        "drawStyle": "line",
                        "fillOpacity": 10,
                        "lineWidth": 2,
                        "stacking": {
                            "mode": "normal"
                        }
                    },
                    "color": {
                        "mode": "palette-classic"
                    }
                }
            }
        },
        {
            "type": "timeseries",
            "title": "GC Committed Memory",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 9
            },
            "datasource": {
                "type": "prometheus",
                "uid": "Prometheus"
            },
            "targets": [
                {
                    "refId": "A",
                    "datasource": {
                        "type": "prometheus",
                        "uid": "Prometheus"
                    },
                    "expr": "dotnet_gc_last_collection_memory_committed_size_bytes{service_name=\"$service\"}",
                    "legendFormat": "{{service_name}}"
                }
            ],
            "options": {
                "legend": {
                    "displayMode": "table",
                    "placement": "bottom",
                    "showLegend": true,
                    "calcs": [
                        "lastNotNull",
                        "max",
                        "mean"
                    ]
                }
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "bytes",
                    "custom": {
                        "drawStyle": "line",
                        "fillOpacity": 10,
                        "lineWidth": 2
                    },
                    "color": {
                        "mode": "palette-classic"
                    }
                }
            }
        },
        {
            "type": "timeseries",
            "title": "GC Heap Fragmentation",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 9
            },
            "datasource": {
                "type": "prometheus",
                "uid": "Prometheus"
            },
            "targets": [
                {
                    "refId": "A",
                    "datasource": {
                        "type": "prometheus",
                        "uid": "Prometheus"
                    },
                    "expr": "dotnet_gc_last_collection_heap_fragmentation_size_bytes{service_name=\"$service\"}",
                    "legendFormat": "Gen {{gc_heap_generation}}"
                }
            ],
            "options": {
                "legend": {
                    "displayMode": "table",
                    "placement": "bottom",
                    "showLegend": true,
                    "calcs": [
                        "lastNotNull",
                        "max"
                    ]
                }
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "bytes",
                    "custom": {
                        "drawStyle": "line",
                        "fillOpacity": 10,
                        "lineWidth": 2
                    },
                    "color": {
                        "mode": "palette-classic"
                    }
                }
            }
        },
        {
            "type": "row",
            "title": "Logs (Loki)",
            "gridPos": {
                "h": 1,
                "w": 24,
                "x": 0,
                "y": 17
            },
            "collapsed": false
        },
        {
            "type": "stat",
            "title": "Errors (5m)",
            "gridPos": {
                "h": 4,
                "w": 6,
                "x": 0,
                "y": 18
            },
            "datasource": {
                "type": "loki",
                "uid": "Loki"
            },
            "targets": [
                {
                    "refId": "A",
                    "datasource": {
                        "type": "loki",
                        "uid": "Loki"
                    },
                    "expr": "sum(count_over_time({service_name=\"$service\"} |~ \"(?i)error\" [5m]))"
                }
            ],
            "options": {
                "graphMode": "area",
                "colorMode": "background",
                "textMode": "auto",
                "reduceOptions": {
                    "values": false,
                    "calcs": [
                        "lastNotNull"
                    ]
                }
            },
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "thresholds"
                    },
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "value": null,
                                "color": "green"
                            },
                            {
                                "value": 1,
                                "color": "red"
                            }
                        ]
                    }
                }
            }
        },
        {
            "type": "stat",
            "title": "Warnings (5m)",
            "gridPos": {
                "h": 4,
                "w": 6,
                "x": 6,
                "y": 18
            },
            "datasource": {
                "type": "loki",
                "uid": "Loki"
            },
            "targets": [
                {
                    "refId": "A",
                    "datasource": {
                        "type": "loki",
                        "uid": "Loki"
                    },
                    "expr": "sum(count_over_time({service_name=\"$service\"} |~ \"(?i)warn\" [5m]))"
                }
            ],
            "options": {
                "graphMode": "area",
                "colorMode": "background",
                "textMode": "auto",
                "reduceOptions": {
                    "values": false,
                    "calcs": [
                        "lastNotNull"
                    ]
                }
            },
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "thresholds"
                    },
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "value": null,
                                "color": "green"
                            },
                            {
                                "value": 1,
                                "color": "yellow"
                            },
                            {
                                "value": 10,
                                "color": "orange"
                            }
                        ]
                    }
                }
            }
        },
        {
            "type": "stat",
            "title": "Info Logs (5m)",
            "gridPos": {
                "h": 4,
                "w": 6,
                "x": 12,
                "y": 18
            },
            "datasource": {
                "type": "loki",
                "uid": "Loki"
            },
            "targets": [
                {
                    "refId": "A",
                    "datasource": {
                        "type": "loki",
                        "uid": "Loki"
                    },
                    "expr": "sum(count_over_time({service_name=\"$service\"} |~ \"(?i)info\" [5m]))"
                }
            ],
            "options": {
                "graphMode": "area",
                "colorMode": "background",
                "textMode": "auto",
                "reduceOptions": {
                    "values": false,
                    "calcs": [
                        "lastNotNull"
                    ]
                }
            },
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "thresholds"
                    },
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "value": null,
                                "color": "blue"
                            }
                        ]
                    }
                }
            }
        },
        {
            "type": "stat",
            "title": "Total Logs (5m)",
            "gridPos": {
                "h": 4,
                "w": 6,
                "x": 18,
                "y": 18
            },
            "datasource": {
                "type": "loki",
                "uid": "Loki"
            },
            "targets": [
                {
                    "refId": "A",
                    "datasource": {
                        "type": "loki",
                        "uid": "Loki"
                    },
                    "expr": "sum(count_over_time({service_name=\"$service\"}[5m]))"
                }
            ],
            "options": {
                "graphMode": "area",
                "colorMode": "background",
                "textMode": "auto",
                "reduceOptions": {
                    "values": false,
                    "calcs": [
                        "lastNotNull"
                    ]
                }
            },
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "thresholds"
                    },
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "value": null,
                                "color": "text"
                            }
                        ]
                    }
                }
            }
        },
        {
            "type": "logs",
            "title": "Recent Logs",
            "gridPos": {
                "h": 12,
                "w": 24,
                "x": 0,
                "y": 22
            },
            "datasource": {
                "type": "loki",
                "uid": "Loki"
            },
            "targets": [
                {
                    "refId": "A",
                    "datasource": {
                        "type": "loki",
                        "uid": "Loki"
                    },
                    "expr": "{service_name=\"$service\"}"
                }
            ],
            "options": {
                "showTime": true,
                "wrapLogMessage": true,
                "showLabels": false,
                "showCommonLabels": false,
                "prettifyLogMessage": false,
                "enableLogDetails": true,
                "dedupStrategy": "none",
                "sortOrder": "Descending"
            }
        }
    ]
}