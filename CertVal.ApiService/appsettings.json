{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "CertVal.ApiService": "Debug",
      "CertVal.Infrastructure": "Debug",
      "CertVal.Application": "Debug"
    }
  },
  "AllowedHosts": "*",
  "JwtSettings": {
    "SecretKey": "SuperSecretKey",
    "Issuer": "CertVal",
    "Audience": "CertVal-Users",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:9995"
    ]
  },
  "GoogleAuth": {
    "ClientId": "GOOGLE_OAUTH_CLIENT_ID.apps.googleusercontent.com"
  },
  "CertificateStorage": {
    "BucketName": "certificates",
    "UseWorkspacePrefixes": true,
    "DeleteOnCertificateRemoval": true,
    "MaxFileSize": 10485760
  },
  "NotificationSettings": {
    "ProcessingInterval": "00:15:00",
    "MaxRetryAttempts": 3,
    "RetryDelay": "00:05:00"
  },
  "RateLimits": {
    "PasswordResetMinutes": 5,
    "InviteMemberMinutes": 5
  }
}