{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "CertVal.ApiService": "Debug",
      "CertVal.Infrastructure": "Debug",
      "CertVal.Application": "Debug"
    }
  },
  "AllowedHosts": "*",
  "JwtSettings": {
    "SecretKey": "SuperSecretKey",
    "Issuer": "CertVal",
    "Audience": "CertVal-Users",
    "ExpiryHours": 24
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:9995"
    ]
  },
  "CertificateStorage": {
    "BucketName": "certificates",
    "UseWorkspacePrefixes": true,
    "DeleteOnCertificateRemoval": true,
    "MaxFileSize": 10485760
  },
  "NotificationSettings": {
    "ProcessingInterval": "00:15:00",
    "MaxRetryAttempts": 3,
    "RetryDelay": "00:05:00"
  },
  "EmailService": {
    "Templates": {
      "BaseUrl": "https://certval.halerka.dev"
    }
  }
}