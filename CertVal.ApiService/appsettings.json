{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "JwtSettings": {
    "SecretKey": "SuperSecretKey",
    "Issuer": "CertVal",
    "Audience": "CertVal-Users",
    "ExpiryHours": 24
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:9995"
    ]
  },
  "FileStorage": {
    "Provider": "Local",
    "BasePath": "wwwroot/uploads",
    "MaxFileSize": 10485760
  },
  "EmailSettings": {
    "SmtpHost": "",
    "SmtpPort": 587,
    "Username": "",
    "Password": "",
    "FromEmail": "",
    "FromName": "CertVal Certificate Monitor",
    "EnableSsl": true
  },
  "NotificationSettings": {
    "ProcessingInterval": "00:15:00",
    "MaxRetryAttempts": 3,
    "RetryDelay": "00:05:00"
  }
}